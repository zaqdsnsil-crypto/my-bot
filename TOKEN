    bot_choice = random.choice(["rock", "paper", "scissors"])
    names = {"rock": "سنگ", "paper": "کاغذ", "scissors": "قیچی"}
    wins = {"rock": "scissors", "paper": "rock", "scissors": "paper"}
    if choice == bot_choice:
        result = "مساوی!"
